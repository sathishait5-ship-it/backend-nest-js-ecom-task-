{
  "name": "backend-nest-app",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "cross-env NODE_ENV=development nest start --watch",
    "start:staging": "cross-env NODE_ENV=staging nest start",
    "start:prod": "cross-env NODE_ENV=production node dist/src/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "cross-env NODE_OPTIONS=\"--no-experimental-webstorage\" jest",
    "test:watch": "cross-env NODE_OPTIONS=\"--no-experimental-webstorage\" jest --watch",
    "test:cov": "cross-env NODE_OPTIONS=\"--no-experimental-webstorage\" jest --coverage",
    "test:debug": "cross-env NODE_OPTIONS=\"--no-experimental-webstorage\" node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-experimental-webstorage\" jest --config ./test/jest-e2e.json",
    "seed": "cross-env NODE_ENV=development ts-node -r tsconfig-paths/register src/database/seeders/seed.ts",
    "seed:roles": "cross-env NODE_ENV=development ts-node -r tsconfig-paths/register src/database/seeders/role.seed.ts",
    "seed:users": "cross-env NODE_ENV=development ts-node -r tsconfig-paths/register src/database/seeders/user.seed.ts",
    "seed:products": "cross-env NODE_ENV=development ts-node -r tsconfig-paths/register src/database/seeders/product.seed.ts"
  },
  "dependencies": {
    "@nestjs-modules/mailer": "^2.0.2",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/throttler": "^6.5.0",
    "bcrypt": "^6.0.0",
    "bull": "^4.16.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "cron": "^4.4.0",
    "dayjs": "^1.11.21",
    "dotenv": "^17.4.2",
    "handlebars": "^4.7.9",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.0",
    "mongoose": "^9.6.2",
    "morgan": "^1.10.1",
    "mqredis": "^0.0.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.9",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/bull": "^3.15.9",
    "@types/cron": "^2.0.1",
    "@types/express": "^5.0.0",
    "@types/handlebars": "^4.0.40",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.3",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "jest-environment-node": "^29.7.0",
    "prettier": "^3.8.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
